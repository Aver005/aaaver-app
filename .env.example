# --- Сервер ---
PORT=3000
# Куда писать SQLite. В докере путь смонтирован на ./data рядом с docker-compose.yml
DATABASE_PATH=./data/aaaver.db

# --- Telegram ---
# Токен бота: @BotFather -> /newbot
TELEGRAM_BOT_TOKEN=
# Свой chat_id: напиши боту /start и выполни `bun run chat-id`.
# Если оставить пустым, сервер сам подхватит chat_id из первого /start
# и сохранит его в БД.
TELEGRAM_CHAT_ID=

# --- Анти-спам ---
# Сложность proof-of-work в битах (12-18 разумно, больше = дольше решается у клиента)
POW_DIFFICULTY=14
# Лимит сообщений с одного IP
RATE_LIMIT_PER_HOUR=5
RATE_LIMIT_PER_DAY=20
# Поставь 1, если сервер стоит за nginx/caddy и реальный IP приходит в X-Forwarded-For
TRUST_PROXY=0

# --- deploy.bat (необязательно) ---
# DEPLOY_HOST=
# DEPLOY_USER=root
# DEPLOY_KEY=C:\ssh\key
# DEPLOY_PATH=aaaver-app
# DEPLOY_COMMAND=docker compose up --build -d
