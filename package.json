{
  "name": "aaaver-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:web": "vite",
    "dev:api": "bun --watch server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "preview": "bun run build && bun run start",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "chat-id": "bun scripts/get-chat-id.ts"
  },
  "dependencies": {
    "@fontsource-variable/golos-text": "^5.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@fontsource-variable/unbounded": "^5.2.5",
    "lucide-react": "^0.561.0",
    "motion": "^12.27.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  }
}
